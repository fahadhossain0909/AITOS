{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specs.aitos.dev/runtime/contracts/event_contract.json",
  "title": "AITOS Runtime Event Contract",
  "description": "Canonical Event Contract for the AITOS Event Bus. Defines the machine-readable structure, validation rules, metadata, routing, security, and compatibility requirements for all runtime events.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec_version",
    "event_id",
    "event_type",
    "source",
    "timestamp",
    "correlation_id",
    "payload",
    "security",
    "routing"
  ],
  "properties": {
    "spec_version": {
      "type": "string",
      "pattern": "^1\\.0\\.0$",
      "description": "Event contract specification version."
    },

    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Globally unique event identifier."
    },

    "event_type": {
      "type": "string",
      "enum": [
        "command",
        "query",
        "request",
        "response",
        "notification",
        "broadcast",
        "workflow",
        "agent",
        "memory",
        "context",
        "registry",
        "governance",
        "security",
        "audit",
        "system",
        "error"
      ]
    },

    "event_name": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_.-]{2,100}$"
    },

    "timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "correlation_id": {
      "type": "string",
      "format": "uuid"
    },

    "causation_id": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },

    "workflow_id": {
      "type": [
        "string",
        "null"
      ]
    },

    "task_id": {
      "type": [
        "string",
        "null"
      ]
    },

    "source": {
      "$ref": "#/$defs/runtime_endpoint"
    },

    "destination": {
      "oneOf": [
        {
          "$ref": "#/$defs/runtime_endpoint"
        },
        {
          "type": "null"
        }
      ]
    },

    "routing": {
      "$ref": "#/$defs/routing"
    },

    "security": {
      "$ref": "#/$defs/security"
    },

    "payload": {
      "type": "object",
      "description": "Business payload carried by the event.",
      "additionalProperties": true
    },

    "metadata": {
      "$ref": "#/$defs/metadata"
    },

    "trace": {
      "$ref": "#/$defs/trace"
    }
  },

  "$defs": {

    "runtime_endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component",
        "instance"
      ],
      "properties": {

        "component": {
          "type": "string",
          "enum": [
            "event_bus",
            "workflow_engine",
            "agent_host",
            "context_engine",
            "memory_engine",
            "registry",
            "scheduler",
            "plugin",
            "api_gateway",
            "external"
          ]
        },

        "instance": {
          "type": "string"
        },

        "agent_id": {
          "type": [
            "string",
            "null"
          ]
        }

      }
    },

    "routing": {

      "type": "object",

      "additionalProperties": false,

      "required": [
        "topic",
        "delivery_mode"
      ],

      "properties": {

        "topic": {
          "type": "string"
        },

        "partition": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },

        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "default": 50
        },

        "delivery_mode": {
          "type": "string",
          "enum": [
            "at_most_once",
            "at_least_once",
            "exactly_once"
          ]
        },

        "ttl_seconds": {
          "type": "integer",
          "minimum": 0
        }

      }

    },

    "security": {

      "type": "object",

      "additionalProperties": false,

      "required": [
        "trust_level",
        "authenticated",
        "authorized"
      ],

      "properties": {

        "authenticated": {
          "type": "boolean"
        },

        "authorized": {
          "type": "boolean"
        },

        "trust_level": {
          "type": "string",
          "enum": [
            "public",
            "internal",
            "trusted",
            "privileged",
            "system"
          ]
        },

        "signature": {
          "type": [
            "string",
            "null"
          ]
        },

        "hash": {
          "type": [
            "string",
            "null"
          ]
        }

      }

    },

    "metadata": {

      "type": "object",

      "additionalProperties": true,

      "properties": {

        "schema_version": {
          "type": "string"
        },

        "producer_version": {
          "type": "string"
        },

        "runtime_version": {
          "type": "string"
        },

        "labels": {
          "type": "object"
        }

      }

    },

    "trace": {

      "type": "object",

      "additionalProperties": false,

      "required": [
        "trace_id",
        "span_id"
      ],

      "properties": {

        "trace_id": {
          "type": "string"
        },

        "span_id": {
          "type": "string"
        },

        "parent_span_id": {
          "type": [
            "string",
            "null"
          ]
        }

      }

    }

  }
}